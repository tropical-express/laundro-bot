# =========================
# 🌍 Overpass API Settings
# =========================
# OpenStreetMap Overpass API endpoint
OVERPASS_URL=https://overpass-api.de/api/interpreter

# Optional: alternative mirror (uncomment if needed)
# OVERPASS_URL=https://overpass.kumi.systems/api/interpreter

# =========================
# 🗄️ Database
# =========================
# Path to SQLite database file
DB_PATH=./data/laundromats.db

# =========================
# ⚙️ n8n Configuration
# =========================
# Host where n8n is running
N8N_HOST=localhost

# Port for n8n (default: 5678)
N8N_PORT=5678

# Protocol (http for local, https for production)
N8N_PROTOCOL=http

# Webhook endpoint (replace with your actual workflow path)
WEBHOOK_URL=http://localhost:5678/webhook/your-endpoint

# =========================
# 📊 Dashboard
# =========================
# Port for your dashboard app
DASHBOARD_PORT=5000

# =========================
# 🚦 Optional Performance Tweaks
# =========================
# Delay between API requests (ms)
# REQUEST_DELAY_MS=2000

# Max concurrent requests
# MAX_CONCURRENT_REQUESTS=2

# Overpass API timeout (ms)
# OVERPASS_TIMEOUT=30000
